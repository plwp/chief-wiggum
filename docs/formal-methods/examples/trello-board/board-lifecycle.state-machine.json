{
  "name": "Board Lifecycle",
  "description": "State machine for Board entity, extracted from domain model",
  "initial": "active",
  "states": {
    "active": {
      "description": "Board in active state",
      "type": "initial"
    },
    "closed": {
      "description": "Board in closed state",
      "type": "normal"
    },
    "deleted": {
      "description": "Board in deleted state",
      "type": "terminal"
    }
  },
  "transitions": [
    {
      "from": "active",
      "to": "closed",
      "event": "close",
      "guards": [
        {
          "id": "guard_close_0",
          "description": "user is authenticated"
        },
        {
          "id": "guard_close_1",
          "description": "user has write access"
        },
        {
          "id": "guard_close_2",
          "description": "board is active"
        }
      ],
      "actions": [
        "board.closed set to true",
        "board moves to closed boards view"
      ]
    },
    {
      "from": "closed",
      "to": "active",
      "event": "reopen",
      "guards": [
        {
          "id": "guard_reopen_0",
          "description": "user is authenticated"
        },
        {
          "id": "guard_reopen_1",
          "description": "user has write access"
        },
        {
          "id": "guard_reopen_2",
          "description": "board is closed"
        }
      ],
      "actions": [
        "board.closed set to false",
        "board reappears in active boards view"
      ]
    },
    {
      "from": "active",
      "to": "deleted",
      "event": "delete",
      "guards": [
        {
          "id": "guard_delete_0",
          "description": "user is authenticated"
        },
        {
          "id": "guard_delete_1",
          "description": "user is board admin"
        }
      ],
      "actions": [
        "board marked as deleted",
        "board no longer appears in member board lists",
        "all lists and cards become inaccessible"
      ]
    },
    {
      "from": "closed",
      "to": "deleted",
      "event": "delete",
      "guards": [
        {
          "id": "guard_delete_0",
          "description": "user is authenticated"
        },
        {
          "id": "guard_delete_1",
          "description": "user is board admin"
        }
      ],
      "actions": [
        "board marked as deleted",
        "board no longer appears in member board lists",
        "all lists and cards become inaccessible"
      ]
    }
  ],
  "invalid_transitions": [
    {
      "from": "deleted",
      "to": "active",
      "reason": "deleted is a terminal state \u2014 no transitions out"
    },
    {
      "from": "deleted",
      "to": "closed",
      "reason": "deleted is a terminal state \u2014 no transitions out"
    }
  ],
  "context": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "desc": {
      "type": "string"
    },
    "closed": {
      "type": "boolean"
    },
    "starred": {
      "type": "boolean"
    },
    "idOrganization": {
      "type": "ObjectID",
      "source_of_truth": "organizations collection"
    },
    "prefs": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "shortUrl": {
      "type": "string"
    },
    "dateLastActivity": {
      "type": "string"
    },
    "memberships": {
      "type": "string"
    }
  },
  "derived_from": [
    {
      "type": "observed_fact",
      "ref": "api-docs-boards"
    },
    {
      "type": "observed_fact",
      "ref": "browser-explore-boards"
    },
    {
      "type": "observed_fact",
      "ref": "help-center-boards"
    }
  ]
}