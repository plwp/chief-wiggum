{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chief-wiggum.dev/schemas/transition-map.json",
  "title": "Transition Map",
  "description": "Maps state machine transitions to user stories and code locations. Generated by verify_transitions.py.",
  "type": "object",
  "required": ["entities", "summary"],
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" },
      "minItems": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repo": {
      "type": "string",
      "description": "Repository path or owner/repo"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["name", "transitions"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Entity name (e.g., Booking, BookingRequest)"
        },
        "model_file": {
          "type": "string",
          "description": "Path to the state machine JSON this entity's model comes from"
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/mappedTransition" }
        },
        "undocumented": {
          "type": "array",
          "items": { "$ref": "#/$defs/undocumentedTransition" },
          "description": "Transitions found in code but not in the state machine model"
        }
      }
    },
    "mappedTransition": {
      "type": "object",
      "required": ["from", "to", "event", "status"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "event": { "type": "string" },
        "tickets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Issue references that introduced this transition (e.g., ['#42', '#43'])"
        },
        "status": {
          "type": "string",
          "enum": ["covered", "missing", "planned"],
          "description": "covered = in model and code, missing = in model but not code, planned = not yet implemented"
        },
        "code_locations": {
          "type": "array",
          "items": { "$ref": "#/$defs/codeLocation" }
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "undocumentedTransition": {
      "type": "object",
      "required": ["to"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string",
          "description": "Source state (or '*' if unknown)"
        },
        "to": { "type": "string" },
        "code_locations": {
          "type": "array",
          "items": { "$ref": "#/$defs/codeLocation" }
        }
      }
    },
    "codeLocation": {
      "type": "object",
      "required": ["file", "line"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "handler": {
          "type": "string",
          "description": "Function/handler name"
        },
        "guard": {
          "type": "string",
          "description": "Status guard found in the handler (e.g., 'status == confirmed')"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_model_transitions", "covered", "missing", "undocumented"],
      "additionalProperties": false,
      "properties": {
        "total_model_transitions": { "type": "integer" },
        "covered": { "type": "integer" },
        "missing": { "type": "integer" },
        "undocumented": { "type": "integer" }
      }
    }
  }
}
